model activity_logs {
  id                    Int                 @id @default(autoincrement())
  utilisateur_id        Int
  app_name              String?             @db.VarChar(255)
  window_title          String?
  is_idle               Boolean?            @default(false)
  idle_seconds          Int?                @default(0)
  activity_signature    String?
  type                  String              @default("active") @db.VarChar(20)
  duration_seconds      Int?
  captured_at           DateTime?           @default(now()) @db.Timestamptz(6)
  organisation_id       Int?
  project_suggestion_id Int?
  confidence_score      Int?                @default(0)
