model activity_app_rules {
  id              Int           @id @default(autoincrement())
  organisation_id Int
  app_pattern     String        @db.VarChar(255)
  title_pattern   String?       @db.VarChar(500)
  category        String        @db.VarChar(80)
  tag             String?       @db.VarChar(80)
  confidence      Int?          @default(70)
  is_productive   Boolean?      @default(true)
  priority        Int?          @default(10)
  active          Boolean?      @default(true)
  created_by      Int?
  created_at      DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at      DateTime?     @default(now()) @db.Timestamptz(6)
  utilisateurs    utilisateurs? @relation(fields: [created_by], references: [id], onUpdate: NoAction)
  organisations   organisations @relation(fields: [organisation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([organisation_id, active], map: "idx_activity_app_rules_org_active")
}

