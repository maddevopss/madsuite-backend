  activity_feedback     activity_feedback[]
  organisations         organisations?      @relation(fields: [organisation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  projets               projets?            @relation(fields: [project_suggestion_id], references: [id], onUpdate: NoAction)
  utilisateurs          utilisateurs        @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_user_log")

  @@index([activity_category], map: "idx_activity_logs_category")
  @@index([organisation_id, deleted_at], map: "idx_activity_logs_deleted_cleanup", where: raw("(deleted_at IS NOT NULL)"))
  @@index([organisation_id, utilisateur_id, captured_at], map: "idx_activity_logs_live_suggestions", where: raw("(is_aggregated = false)"))
  @@index([organisation_id], map: "idx_activity_logs_org_id")
  @@index([organisation_id, utilisateur_id, captured_at], map: "idx_activity_logs_org_user_time")
  @@index([organisation_id, utilisateur_id, captured_at], map: "idx_activity_logs_org_user_time_active", where: raw("(deleted_at IS NULL)"))
  @@index([organisation_id, captured_at], map: "idx_activity_logs_purge_ready", where: raw("(is_aggregated = true)"))
  @@index([organisation_id, captured_at], map: "idx_activity_logs_retention_lookup", where: raw("(deleted_at IS NULL)"))
  @@index([utilisateur_id, activity_signature], map: "idx_activity_logs_signature", where: raw("(activity_signature IS NOT NULL)"))
  @@index([type], map: "idx_activity_logs_type")
  @@index([utilisateur_id], map: "idx_activity_logs_user_id")
  @@index([utilisateur_id, captured_at], map: "idx_activity_logs_user_time")
}

