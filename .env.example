# MADSuite Backend — Environment Example
# Source de vérité documentaire : bleeband/SYSTEME_MAD
# Ne jamais commiter de fichier .env réel.

# ============================================================================
# ENVIRONMENT
# ============================================================================
NODE_ENV=development
PORT=5000

# ============================================================================
# AUTH & SECURITY
# ============================================================================
# CRITICAL: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=YOUR_32_CHAR_RANDOM_SECRET_HERE

ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# ============================================================================
# DATABASE
# ============================================================================
# Option A: individual connection fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=madsuite
DB_USER=postgres
DB_PASSWORD=YOUR_STRONG_PASSWORD_HERE

# Option B: connection string if used by the runtime / Prisma / Neon
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=15000
DB_STATEMENT_TIMEOUT_MS=15000
DB_MAX_POOL_SIZE=20

# ============================================================================
# EXTERNAL APIS
# ============================================================================
OPEN_AI_KEY=
OPENAI_API_KEY=
AI_ASSISTANT_ENABLED=false

STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_PRICE_ID=

# ============================================================================
# EMAIL
# ============================================================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=info@maddevops.com
EMAIL_PASS=YOUR_GMAIL_APP_PASSWORD_HERE
EMAIL_FROM="MADSuite <info@maddevops.com>"

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# ============================================================================
# CACHE & JOBS
# ============================================================================
REDIS_URL=redis://localhost:6379
REDIS_DISABLED=true
SCHEDULERS_ENABLED=true
TRIAL_REMINDER_JOB_ENABLED=true
RETENTION_JOB_ENABLED=true

# ============================================================================
# ADMIN & SEED DATA
# ============================================================================
SEED_ADMIN_EMAIL=admin@test.com
SEED_ADMIN_PASSWORD=YOUR_STRONG_PASSWORD_HERE
MASTER_ADMIN_USER_IDS=1,2,3

# ============================================================================
# TESTING
# ============================================================================
TEST_DB_NAME=madsuite_test
TEST_EMAIL_HOST=localhost
TEST_EMAIL_PORT=1025
TEST_EMAIL_USER=test
TEST_EMAIL_PASS=test
TEST_ADMIN_EMAIL=admin@example.com
TEST_PASSWORD=change-me
TEST_BASE_URL=http://localhost:5000

# ============================================================================
# FRONTEND, ELECTRON & CORS
# ============================================================================
# Production must use exact origins only. Do not use wildcard Vercel origins.
FRONTEND_URL=http://localhost:3000
ELECTRON_URL=http://localhost:3000
VERCEL_FRONTEND_URL=
# Optional comma-separated exact origins for controlled previews or temporary domains.
ALLOWED_CORS_ORIGINS=

# ============================================================================
# OBSERVABILITY / LOGGING
# ============================================================================
SENTRY_DSN=
# Production defaults in server.js are 0.1 traces and 0.05 profiles if unset.
SENTRY_TRACES_SAMPLE_RATE=
SENTRY_PROFILES_SAMPLE_RATE=
LOG_LEVEL=debug
LOG_MAX_SIZE_BYTES=5242880
LOG_MAX_FILES=5
ACTIVITY_LOG_RETENTION_DAYS=30
LONG_TIMER_THRESHOLD_HOURS=8

# ============================================================================
# MIGRATIONS / BACKUP
# ============================================================================
SKIP_MIGRATIONS=0
ENABLE_DB_BACKUP=0

# ============================================================================
# INVOICING
# ============================================================================
INVOICE_BRAND_NAME=MADSuite
INVOICE_BRAND_EMAIL=facturation@example.com
INVOICE_BRAND_PHONE=
INVOICE_BRAND_WEBSITE=https://example.com
INVOICE_BRAND_ADDRESS=
INVOICE_TAX_NUMBERS=
INVOICE_CURRENCY=CAD
INVOICE_PAYMENT_TERMS=Payable dans les 30 jours
INVOICE_BRAND_COLOR=#29529b
INVOICE_BRAND_FOOTER=Generated by MADSuite

# ============================================================================
# JOBS & CLEANUP
# ============================================================================
PURGE_LOCK_ID=86400
PURGE_BATCH_LIMIT=5000
