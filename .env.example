# MADSuite Backend — Exemple d'environnement (à adapter)
# ⚠️ Ne met pas de vraies valeurs de secrets dans le repo.

# Node
NODE_ENV=production
PORT=5000

# JWT
JWT_SECRET=replace_with_32plus_chars_MixedCase_123!
ACCESS_TOKEN_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=madsuite
DB_USER=postgres
DB_PASSWORD=change_me
DB_CONNECTION_TIMEOUT_MS=5000
DB_IDLE_TIMEOUT_MS=30000
DB_QUERY_TIMEOUT_MS=15000
DB_STATEMENT_TIMEOUT_MS=15000

# Configuration Email (SMTP)
EMAIL_HOST=smtp.exemple.com
EMAIL_PORT=465
EMAIL_USER=info@email.com
EMAIL_PASS=ton_code_application_de_16_lettres

# Pour les tests (Maildev ou Mock)
TEST_EMAIL_HOST=localhost
TEST_EMAIL_PORT=1025
TEST_EMAIL_USER=test
TEST_EMAIL_PASS=test


# Logs
LOG_MAX_SIZE_BYTES=5242880
LOG_MAX_FILES=5

# Retention des activity_logs bruts (1 a 365 jours)
ACTIVITY_LOG_RETENTION_DAYS=30

# Desktop agent capture queue
AGENT_CAPTURE_QUEUE_MAX_ITEMS=100          # Flush when queue reaches this
AGENT_CAPTURE_QUEUE_FLUSH_DELAY_MS=30000   # Flush every 30 seconds
AGENT_CAPTURE_QUEUE_MAX_BYTES=2000000      # Max payload size
AGENT_CAPTURE_QUEUE_TTL_MS=604800000       # 7 days retention

# Tests Jest / PostgreSQL
# TEST_DB_NAME doit finir par _test: le setup Jest supprime/recree cette base.
TEST_DB_NAME=madsuite_test
# Optionnel si tu preferes des URLs completes.
# POSTGRES_ADMIN_URL=postgres://postgres:change_me@localhost:5432/postgres
# TEST_DATABASE_URL=postgres://postgres:change_me@localhost:5432/madsuite_test

# CORS (frontend web + desktop)
# Mettre l'URL exacte utilisée par le frontend Vite en dev ou prod.
FRONTEND_URL=https://app.madsuite.com
ELECTRON_URL=https://app.madsuite.com

# Seed (optionnel si tu utilises backend/seed.js en prod)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me

# Seuil pour considérer un timer comme "long" (en heures)
LONG_TIMER_THRESHOLD_HOURS=8

# Branding PDF factures
INVOICE_BRAND_NAME=MADSuite
INVOICE_BRAND_EMAIL=facturation@example.com
INVOICE_BRAND_PHONE=
INVOICE_BRAND_WEBSITE=https://example.com
INVOICE_BRAND_ADDRESS=
INVOICE_TAX_NUMBERS=
INVOICE_CURRENCY=CAD
INVOICE_PAYMENT_TERMS=Payable dans les 30 jours
INVOICE_BRAND_COLOR=#29529b
INVOICE_BRAND_FOOTER=Genere par MADSuite


