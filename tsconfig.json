{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2020",

    "lib": ["ES2020"],
    "types": ["node"],

    "esModuleInterop": true,
    "skipLibCheck": true,

    "strict": true,

    "sourceMap": true,

    "declaration": true,
    "declarationMap": true,

    "verbatimModuleSyntax": false,
    "moduleDetection": "force"
  },

  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
