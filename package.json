{
  "name": "backend",
  "version": "2.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "build": "node -c server.js",
    "check:backend": "npm run guard:gitignore && npm run guard:hygiene && npm run guard:routes && npm run guard:organisation-routes && npm run guard:modules-contract && npm run guard:module-access-contract && npm run guard:app-module-mounts && npm run guard:public-kiosk-modules && npm run guard:public-portal-contract && npm run guard:stripe-contract && npm run guard:activity-ingestion-contract && npm run guard:ai-contract && npm run guard:cognitive-contract && npm run guard:hub-contract && npm run guard:notifications-contract && npm run guard:export-contract && npm run guard:analytics-contract && npm run guard:calendar-contract && npm run guard:suggestions-summary-contract && npm run guard:master-admin-contract && npm run guard:reports-contract && npm run test:modules && npm test -- --runInBand && npm run test:security -- --runInBand && npm run lint",
    "start": "node server.js",
    "dev": "nodemon server.js",
    "postinstall": "prisma generate",
    "test": "cross-env NODE_ENV=test jest --detectOpenHandles --forceExit",
    "test:coverage": "cross-env NODE_ENV=test jest --coverage --detectOpenHandles --forceExit",
    "test:db:reset": "cross-env NODE_ENV=test node src/test/setupInvoicesTestDB.js",
    "test:modules": "cross-env NODE_ENV=test jest src/test/modulesRegistry.test.js src/test/modulesService.test.js src/test/requireModule.test.js --runInBand --detectOpenHandles --forceExit",
    "test:security": "cross-env NODE_ENV=test jest src/test/requireSuperAdmin.security.test.js src/test/migrations.integration.test.js src/test/multiTenantJobs.security.test.js --detectOpenHandles --forceExit",
    "guard:gitignore": "node scripts/guard-gitignore-policy.js",
    "guard:hygiene": "node scripts/guard-repo-hygiene.js",
    "guard:routes": "node scripts/guard-route-security.js",
    "guard:organisation-routes": "node scripts/guard-organisation-routes.js",
    "guard:modules-contract": "node scripts/guard-modules-contract.js",
    "guard:module-access-contract": "node scripts/guard-module-access-contract.js",
    "guard:app-module-mounts": "node scripts/guard-app-module-mounts.js",
    "guard:public-kiosk-modules": "node scripts/guard-public-kiosk-modules.js",
    "guard:public-portal-contract": "node scripts/guard-public-portal-contract.js",
    "guard:stripe-contract": "node scripts/guard-stripe-contract.js",
    "guard:activity-ingestion-contract": "node scripts/guard-activity-ingestion-contract.js",
    "guard:ai-contract": "node scripts/guard-ai-contract.js",
    "guard:cognitive-contract": "node scripts/guard-cognitive-contract.js",
    "guard:hub-contract": "node scripts/guard-hub-contract.js",
    "guard:notifications-contract": "node scripts/guard-notifications-contract.js",
    "guard:export-contract": "node scripts/guard-export-contract.js",
    "guard:analytics-contract": "node scripts/guard-analytics-contract.js",
    "guard:calendar-contract": "node scripts/guard-calendar-contract.js",
    "guard:suggestions-summary-contract": "node scripts/guard-suggestions-summary-contract.js",
    "guard:master-admin-contract": "node scripts/guard-master-admin-contract.js",
    "guard:reports-contract": "node scripts/guard-reports-contract.js",
    "start:test": "cross-env NODE_ENV=test node server.js",
    "aggregate:logs": "node src/jobs/runAggregateActivityLogs.js",
    "lint": "eslint src/**/*.js",
    "db:preflight:org": "node src/migrate/preflightOrganisationScope.js",
    "db:migrate": "node -e \"require('./src/migrate/runMigrations').runMigrations({ backup: process.env.ENABLE_DB_BACKUP === '1' }).then(()=>process.exit(0)).catch(e=>{ console.error(e.message); process.exit(1); })\"",
    "deploy:migrate": "cross-env NODE_ENV=production npm run db:migrate"
  },
  "keywords": [],
  "author": "MAD",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@sentry/node": "^10.59.0",
    "@sentry/profiling-node": "^10.59.0",
    "axios": "^1.18.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "crypto": "^1.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^8.5.2",
    "form-data": "^4.0.6",
    "helmet": "^8.1.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "neon": "^2.1.2",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^9.0.1",
    "openai": "^6.44.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.2",
    "swagger-ui-express": "^5.0.0",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.5.0",
    "eslint-plugin-promise": "^6.2.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3"
  }
}
